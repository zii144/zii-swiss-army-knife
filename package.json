{
  "name": "zii-swiss-army-knife",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-market, privacy-first everyday utility suite (PWA + Capacitor).",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @zii/app dev",
    "preview": "pnpm --filter @zii/app preview",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "check:licenses": "node scripts/check-licenses.mjs",
    "check:audit": "pnpm audit --prod --audit-level=high",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm check:licenses && pnpm check:audit"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^26.1.1",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  }
}
