{
  "name": "@zii/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "UI System & PWA App Shell — registry/command-palette surface for the Zii utility suite (M3).",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "build": "vite build && node scripts/check-bundle.mjs && vite build --ssr src/lib/prerender-entry.ts --outDir dist-ssr --emptyOutDir && node scripts/prerender.mjs && node scripts/stamp-sw.mjs",
    "build:spa": "vite build",
    "check:bundle": "node scripts/check-bundle.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "mobile:sync": "pnpm build:spa && cap sync",
    "mobile:ios": "pnpm mobile:sync && cap open ios",
    "mobile:android": "pnpm mobile:sync && cap open android"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1",
    "@e965/xlsx": "0.20.3",
    "@imgly/background-removal": "^1",
    "@zii/calc": "workspace:*",
    "@zii/calendar": "workspace:*",
    "@zii/compute": "workspace:*",
    "@zii/compute-wasm": "workspace:*",
    "@zii/hello-tool": "workspace:*",
    "@zii/id": "workspace:*",
    "@zii/locale": "workspace:*",
    "@zii/payroll": "workspace:*",
    "@zii/receipt": "workspace:*",
    "@zii/registry": "workspace:*",
    "@zii/reminders": "workspace:*",
    "@zii/text": "workspace:*",
    "bwip-js": "^4",
    "fast-xml-parser": "^5.10.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tesseract.js": "^5"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "vite": "^7.3.6"
  }
}
