{
  "name": "@zii/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "UI System & PWA App Shell — registry/command-palette surface for the Zii utility suite (M3).",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "build": "vite build && node scripts/check-bundle.mjs && vite build --ssr src/lib/prerender-entry.ts --outDir dist-ssr --emptyOutDir && node scripts/prerender.mjs",
    "build:spa": "vite build",
    "check:bundle": "node scripts/check-bundle.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "@imgly/background-removal": "^1",
    "@zii/calc": "workspace:*",
    "@zii/calendar": "workspace:*",
    "@zii/compute": "workspace:*",
    "@zii/compute-wasm": "workspace:*",
    "@zii/hello-tool": "workspace:*",
    "@zii/id": "workspace:*",
    "@zii/locale": "workspace:*",
    "@zii/payroll": "workspace:*",
    "@zii/receipt": "workspace:*",
    "@zii/registry": "workspace:*",
    "@zii/reminders": "workspace:*",
    "@zii/text": "workspace:*",
    "bwip-js": "^4",
    "fast-xml-parser": "^4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tesseract.js": "^5",
    "xlsx": "^0.18"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "vite": "^7.3.6"
  }
}
